{
  "name": "mermaid-extension",
  "version": "1.0.0",
  "description": "A Gemini CLI extension specialized in creating diagrams and architectures using Mermaid.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlosrgomes/mermaid-extension.git"
  },
  "keywords": [
    "gemini-cli-extension",
    "mcp",
    "mermaid",
    "diagrams"
  ],
  "homepage": "https://github.com/carlosrgomes/mermaid-extension#readme",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "vitest run",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "build": "tsc",
    "package": "npm run build && shx mkdir -p dist && shx cp gemini-extension.json GEMINI.md dist/ && shx cp -R skills dist/"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "shx": "^0.4.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
